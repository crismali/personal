  Content-Security-Policy: default-src 'none'; script-src 'self' __INLINE_SCRIPT_HASH__; style-src 'self' __INLINE_STYLE_HASHES__; font-src 'self'; img-src 'self'; connect-src 'self'; form-action 'none'; base-uri 'none'; frame-ancestors 'none'; require-trusted-types-for 'script'; trusted-types default
